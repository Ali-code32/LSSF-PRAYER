<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>LSF Prayer Night System</title>

<style>
    body {
        
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        text-align: center;
    
        background: url("bck.jpeg") ;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-size: cover;
    }
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;

        background: rgba(0,0,0,0.5);
        z-index: -1;

    }

    .header {
        background: linear-gradient(135deg, #960e0e, #8b1313);
        color: white;
        padding: 30px 20px;
    }

    .header img {
        width: 300px;
        height: 300px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 10px;
        border: 3px solid white;
        background: white;
    }

    .container {
        max-width: 750px;
        margin: 20px auto;
        background: white;
        text-align: center;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0px 5px 20px rgba(0,0,0,0.1);
    }

    h3 {
        margin: 10px 0 5px;
    }

    p {
        color: #eee;
    }

    button {
        padding: 14px 25px;
        font-size: 16px;
        cursor: pointer;
        border: none;
        background: #2a5298;
        color: white;
        border-radius: 8px;
        margin-top: 15px;
        transition: 0.3s;
    }
    


    button:hover {
        background: #1e3c72;
    }


    .result {
        margin-top: 20px;
        font-size: 18px;
        font-weight: bold;
        color: #5e2ac7;
        min-height: 40px;
    }

    .list {
        text-align: center;
        margin-top: 20px;
        background: #f7f9fc;
        padding: 15px;
        border-radius: 10px;
    }

    .count {
        margin-top: 10px;
        font-size: 14px;
        color: #555;
    }

    .theme {
        font-style: italic;
        margin-top: 5px;
    }

    #toast {
    visibility: hidden;
    min-width: 280px;
    background: linear-gradient(135deg, #28a745, #43d66c);
    color: white;
    text-align: center;
    border-radius: 12px;
    padding: 16px;
    position: fixed;
    z-index: 999;
    left: 50%;
    bottom: 30px;
    transform: translateX(-50%);
    font-size: 16px;
    font-weight: bold;
    box-shadow: 0 6px 18px rgba(0,0,0,0.2);
    opacity: 0;
    transition: opacity 0.5s, bottom 0.5s;
}

#toast.show {
    visibility: visible;
    opacity: 1;
    bottom: 50px;
}

.prayer-card {
    margin-top: 20px;
    padding: 20px;
    background: linear-gradient(135deg, #ffffff, #f0f7ff);
    border-radius: 16px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    animation: fadeIn 0.6s ease;
}

.prayer-card h3 {
    margin: 0 0 10px;
    color: hsl(218, 62%, 61%);
}

.prayer-card p {
    font-size: 18px;
    color: #222;
    font-weight: 600;
}

.prayer-card small {
    color: #666;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(15px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}


</style>
</head>

<body>
<div class =" overlay"></div>
<!-- HEADER -->
<div class="header">
    <img src="logo.jpg" alt="LSF Logo">

    <h1>Lutheran Students and Staff Fellowship</h1>

    <p><b>Theme:</b> Galatians 5:9</p>

    <p class="theme">
        “In the Freedom We Received.May we Stand Firm in Faith.”
    </p>
</div>
<div class ="container">
    <h3>Submit a Prayer Request</h3>
   <h5><i>Do not be anxious about anything, but in every situation, by prayer and petition, let your requests be made known to God.</i></h5>

<input type="text" id="requestInput" placeholder="Type your prayer request..." style="width: 70%; padding: 10px;">

<br>

<button onclick="addRequest()">Submit Request</button>
</div>
<!-- MAIN -->
<div class="container">

    <h2>Gather in Prayer </h2>
    

<ul id="requestList" style="text-align:left; margin-top:15px;"></ul>
    <p></p>Each member receives a unique prayer point. No duplicates.</p>

    <button onclick="pickPrayer()">Receive Prayer Point</button>

    <div class="result" id="result"></div>

    <div class="count" id="count"></div>

    <div class="list">
        <h3>"Worry About nothing, pray about everything"</h3>
        <p5>-Philippians 4:6
        </p5>
        <ul id="prayerList"></ul>
    </div>
    
</div>

<!-- FIREBASE -->
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>

<script>
   const firebaseConfig = {
    apiKey: "AIzaSyBYSNib0jHPwQe5YeAnXxrmuhGL1BZ5KRM",
    authDomain: "lssf-prayer-system.firebaseapp.com",
    databaseURL: "https://lssf-prayer-system-default-rtdb.asia-southeast1.firebasedatabase.app/",
    projectId: "lssf-prayer-system",
    storageBucket: "lssf-prayer-system.appspot.com",
    messagingSenderId: "1081573248563",
    appId: "1:1081573248563:web:4ac230926442c80f0a1d46"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();
let priorityPrayers = [];
let firebaseLoaded = false;

db.ref("priorityPrayers").on("value", snap => {
    priorityPrayers = [];

   snap.forEach(child => {
    const data = child.val();

    // HARD FILTER: must be valid object + valid text
    if (!data || typeof data !== "object") return;
    if (typeof data.text !== "string") return;

    priorityPrayers.push({
        key: child.key,
        text: data.text.trim(),
        used: data.used === true
    });
});

   
    priorityPrayers = priorityPrayers.filter(p => p && p.text);

    firebaseLoaded = true;
    console.log("Firebase loaded:", priorityPrayers);
});







    function addRequest() {
    const input = document.getElementById("requestInput");
    const text = input.value.trim();

    if (!text) return;

    db.ref("priorityPrayers").push({
        text: text,
        used: false,
        time: Date.now()
    });

    input.value = "";

    showToast("🙏 Thank you for sharing your request");
}





