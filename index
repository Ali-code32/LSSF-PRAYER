function pickPrayer() {

    if (!firebaseLoaded) {
        document.getElementById("result").innerText =
            "Loading prayers... please wait.";
        return;
    }

    let selected = null;

    // PRIORITY PRAYERS FIRST
   if (priorityPrayers.length > 0) {

    const available = priorityPrayers.filter(p => p?.text);

    if (available.length === 0) {
        document.getElementById("result").innerText =
            "No valid prayer found.";
        return;
    }

    const index = Math.floor(Math.random() * available.length);
    const item = available[index];

    if (!item || !item.text) {
        document.getElementById("result").innerText =
            "Error loading prayer.";
        return;
    }

    selected = item.text;

    db.ref("priorityPrayers/" + item.key).update({
        used: true
    });
}


    // NORMAL PRAYERS
    else if (prayers.length > 0) {
        const index = Math.floor(Math.random() * prayers.length);
        selected = prayers[index];
        prayers.splice(index, 1);
    }

    else {
        document.getElementById("result").innerText =
            "All prayer points have been assigned.";
        return;
    }

    document.getElementById("result").innerHTML = `
        <div class="prayer-card">
            <h3>🙏 Today's Prayer Focus</h3>
            <p>${selected}</p>
            <small>Stand in faith and pray boldly.</small>
        </div>
    `;
}






function showToast(message) {
    const toast = document.getElementById("toast");

    toast.innerText = message;
    toast.className = "show";

    setTimeout(() => {
        toast.className = toast.className.replace("show", "");
    }, 3000);
}

function uploadAllPrayersToFirebase() {
    prayers.forEach(text => {
        db.ref("prayers").push({
            text: text,
            used: false,
            type: "normal",
            time: Date.now()
        });
    });

    console.log("All prayers uploaded!");
}



</script>
<div id="toast"></div>
</body>
</html>
